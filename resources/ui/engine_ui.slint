import {
    VerticalBox,
    HorizontalBox,
    CheckBox,
    LineEdit,
    Button,
    ScrollView,
    ComboBox,
} from "std-widgets.slint";

import { Theme } from "components/theme.slint";
import { SectionHeader } from "components/section_header.slint";
import { LabeledSlider } from "components/labeled_slider.slint";
import { DataRow } from "components/data_row.slint";
import { Panel, PanelHeader } from "components/panel.slint";

// re-export PauseMenu so it's available via include_modules!()
export { PauseMenu } from "pause_menu.slint";

export component EngineUI inherits Window {
    background: transparent;
    in property <string> position_text: "x: 0.0 y: 0.0 z: 0.0";
    in property <string> player_state_text: "Init";
    in property <string> attack_state_text: "Attack1";
    in property <string> current_animation_text: "Idle";
    in-out property <bool> player_panel_expanded: true;
    in-out property <bool> entity_editor_expanded: true;
    in property <bool> editor_visible: false;
    in-out property <float> dir_light_x: 0.0;
    in-out property <float> dir_light_y: 1.0;
    in-out property <float> dir_light_z: -1.0;
    in-out property <float> dir_light_distance: 32.797;
    in-out property <bool> shadow_debug: false;
    in-out property <float> ortho_near: 0.6;
    in-out property <float> ortho_far: 115.756;
    in-out property <float> bounds: 17.5;
    in-out property <float> bias_scalar: 0.002;
    in-out property <float> master_volume: 1.0;
    callback dir_light_changed();
    callback shadow_debug_changed(bool);
    callback ortho_near_changed(float);
    callback ortho_far_changed(float);
    callback bounds_changed(float);
    callback bias_scalar_changed(float);
    callback pause_music();
    callback play_music();
    callback volume_changed(float);
    callback save_entity_state();
    in-out property <string> new_faction_name: "";
    callback save_faction();
    in property <[string]> entity_types: [];
    in property <[string]> factions: [];
    in-out property <int> entity_type_index: 0;
    in-out property <int> faction_index: 0;
    in-out property <int> weapon_type_index: 0;
    in-out property <bool> include_weapon: false;
    in-out property <float> base_speed: 0.0;
    in-out property <bool> create_mode: false;
    callback create_mode_changed(bool);
    in-out property <bool> lights_expanded: true;
    in-out property <bool> sound_expanded: true;
    in-out property <bool> editing_expanded: true;
	    in-out property <bool> placing_expanded: true;

	    // ==================== PARTICLE EDITOR PROPERTIES ====================
	    in-out property <bool> particle_panel_expanded: true;
	    in property <[string]> emitter_types: [];
	    in-out property <int> emitter_type_index: 0;
	    in-out property <string> staged_texture: "";
	    in-out property <string> pe_emitter_name: "";
	    in-out property <float> pe_pos_x: 0.0;
	    in-out property <float> pe_pos_y: 0.0;
	    in-out property <float> pe_pos_z: 0.0;
	    in-out property <float> pe_dir_x: 0.0;
	    in-out property <float> pe_dir_y: 1.0;
	    in-out property <float> pe_dir_z: 0.0;
	    in-out property <float> pe_angle_min: 0.0;
	    in-out property <float> pe_angle_max: 6.28318;
	    in-out property <float> pe_radius_min: 0.0;
	    in-out property <float> pe_radius_max: 0.0;
	    in-out property <float> pe_jitter_min: 0.0;
	    in-out property <float> pe_jitter_max: 0.2;
	    in-out property <float> pe_gravity: 0.0;
	    in-out property <float> pe_radial_speed_min: 0.0;
	    in-out property <float> pe_radial_speed_max: 1.0;
	    in-out property <float> pe_up_speed_min: 1.0;
	    in-out property <float> pe_up_speed_max: 2.0;
	    in-out property <float> pe_lifetime_min: 0.3;
	    in-out property <float> pe_lifetime_max: 1.0;
	    in-out property <float> pe_particle_count: 10.0;
	    in-out property <float> pe_pps: 0.0;
	    in-out property <float> pe_base_alpha_min: 1.0;
	    in-out property <float> pe_base_alpha_max: 1.0;
	    in-out property <float> pe_alpha_multiplier: 0.0;
	    in-out property <float> pe_alpha_power: 1.0;
	    in-out property <float> pe_base_scale_min: 0.08;
	    in-out property <float> pe_base_scale_max: 0.1;
	    in-out property <float> pe_scale_multiplier: 1.0;
	    in-out property <float> pe_scale_power: 1.0;
	    in-out property <float> pe_color_r: 1.0;
	    in-out property <float> pe_color_g: 1.0;
	    in-out property <float> pe_color_b: 1.0;
	    in-out property <float> pe_color_a: 1.0;
	    in-out property <string> pe_texture_path: "";
	    in-out property <bool> pe_texture_has_alpha: false;
	    in-out property <bool> pe_do_render: false;
	    in-out property <bool> pe_save_toggle: false;
	    in-out property <bool> pe_use_staged_texture_toggle: false;

    // ==================== PLAYER DEBUG PANEL ====================
    Panel {
        x: 10px;
        y: 10px;
        panel-width: 320px;
        panel-height: player_panel_expanded ? 140px : 30px;
        VerticalLayout {
            padding: 8px;
            spacing: 4px;
            PanelHeader {
                title: "Player Data";
                expanded <=> player_panel_expanded;
            }

            if player_panel_expanded: VerticalLayout {
                spacing: 4px;
                padding-top: 4px;
                DataRow {
                    label: "Position";
                    value: position_text;
                }

                DataRow {
                    label: "Player State";
                    value: player_state_text;
                }

                DataRow {
                    label: "Attack State";
                    value: attack_state_text;
                }

                DataRow {
                    label: "Current Animation";
                    value: current_animation_text;
                }
            }
        }
    }

		// ==================== ENTITY EDITOR PANEL ====================
		if editor_visible: Panel {
		    x: 10px;
		    y: player_panel_expanded ? 160px : 50px;
		    panel-width: 380px;
		    panel-height: entity_editor_expanded ? 500px : 30px;
		
		    PanelHeader {
		        x: 8px;
		        y: 4px;
		        width: parent.width - 16px;
		        title: "Entity Editor";
		        expanded <=> entity_editor_expanded;
		    }
		
		    if entity_editor_expanded: ScrollView {
		        x: 0px;
		        y: 28px; // header height (20px) + 8px margin
		        width: parent.width;
		        height: parent.height - 28px;
		
		        VerticalLayout {
	            padding: 8px;
	            spacing: 6px;

	            // =============== LIGHTS SECTION ===============
	            SectionHeader {
	                title: "Controls for Various Lights";
	                expanded <=> lights_expanded;
	            }

	            if lights_expanded: VerticalLayout {
	                spacing: 4px;
	                padding-left: 8px;
	                LabeledSlider {
	                    label: "Dir Light X";
	                    minimum: -1.0;
	                    maximum: 1.0;
	                    value <=> dir_light_x;
	                    changed(v) => {
	                        dir_light_changed();
	                    }
	                }

	                LabeledSlider {
	                    label: "Dir Light Y";
	                    minimum: -1.0;
	                    maximum: 1.0;
	                    value <=> dir_light_y;
	                    changed(v) => {
	                        dir_light_changed();
	                    }
	                }

	                LabeledSlider {
	                    label: "Dir Light Z";
	                    minimum: -1.0;
	                    maximum: 1.0;
	                    value <=> dir_light_z;
	                    changed(v) => {
	                        dir_light_changed();
	                    }
	                }

	                LabeledSlider {
	                    label: "Dir Light Distance";
	                    minimum: 0.0;
	                    maximum: 100.0;
	                    value <=> dir_light_distance;
	                    changed(v) => {
	                        dir_light_changed();
	                    }
	                }

	                HorizontalLayout {
	                    height: 24px;
	                    spacing: 8px;
	                    CheckBox {
	                        text: "Shadow Debug";
	                        checked <=> shadow_debug;
	                        toggled => {
	                            shadow_debug_changed(shadow_debug);
	                        }
	                    }
	                }

	                LabeledSlider {
	                    label: "Ortho Near";
	                    minimum: 0.0;
	                    maximum: 10.0;
	                    value <=> ortho_near;
	                    changed(v) => {
	                        ortho_near_changed(v);
	                    }
	                }

	                LabeledSlider {
	                    label: "Ortho Far";
	                    minimum: 0.0;
	                    maximum: 500.0;
	                    value <=> ortho_far;
	                    changed(v) => {
	                        ortho_far_changed(v);
	                    }
	                }

	                LabeledSlider {
	                    label: "Bounds";
	                    minimum: 0.0;
	                    maximum: 100.0;
	                    value <=> bounds;
	                    changed(v) => {
	                        bounds_changed(v);
	                    }
	                }

	                LabeledSlider {
	                    label: "Bias Scalar";
	                    minimum: 0.0;
	                    maximum: 0.01;
	                    value <=> bias_scalar;
	                    changed(v) => {
	                        bias_scalar_changed(v);
	                    }
	                }
	            }

	            // =============== SOUND SECTION ===============
	            SectionHeader {
	                title: "Controls Fmod Sounds";
	                expanded <=> sound_expanded;
	            }

	            if sound_expanded: VerticalLayout {
	                spacing: 4px;
	                padding-left: 8px;
	                HorizontalLayout {
	                    height: 28px;
	                    spacing: 8px;
	                    Button {
	                        text: "Pause";
	                        clicked => {
	                            pause_music();
	                        }
	                    }

	                    Button {
	                        text: "Play";
	                        clicked => {
	                            play_music();
	                        }
	                    }
	                }

	                LabeledSlider {
	                    label: "Volume";
	                    minimum: 0.0;
	                    maximum: 1.0;
	                    value <=> master_volume;
	                    changed(v) => {
	                        volume_changed(v);
	                    }
	                }
	            }

	            // =============== ENTITY EDITING SECTION ===============
	            SectionHeader {
	                title: "Entity Editing";
	                expanded <=> editing_expanded;
	            }

	            if editing_expanded: VerticalLayout {
	                spacing: 4px;
	                padding-left: 8px;
	                Button {
	                    text: "Save Entity State";
	                    clicked => {
	                        save_entity_state();
	                    }
	                }

	                // Faction creation
	                HorizontalLayout {
	                    height: 28px;
	                    spacing: 8px;
	                    padding-top: 8px;
	                    LineEdit {
	                        width: 180px;
	                        placeholder-text: "New Faction Name";
	                        text <=> new_faction_name;
	                    }

	                    Button {
	                        text: "Save Faction";
	                        clicked => {
	                            save_faction();
	                        }
	                    }
	                }
	            }

	            // =============== PLACING ENTITIES SECTION ===============
	            SectionHeader {
	                title: "Placing Entities";
	                expanded <=> placing_expanded;
	            }

	            if placing_expanded: VerticalLayout {
	                spacing: 4px;
	                padding-left: 8px;

	                // Entity Type dropdown
	                HorizontalLayout {
	                    spacing: 8px;
	                    Text {
	                        text: "Entity Type:";
	                        color: Theme.text-secondary;
	                        font-size: 11px;
	                        vertical-alignment: center;
	                        width: 80px;
	                    }
	                }

	                ComboBox {
	                    model: entity_types;
	                    current-index <=> entity_type_index;
	                }

	                // Faction dropdown
	                HorizontalLayout {
	                    spacing: 8px;
	                    padding-top: 4px;
	                    Text {
	                        text: "Faction:";
	                        color: Theme.text-secondary;
	                        font-size: 11px;
	                        vertical-alignment: center;
	                        width: 80px;
	                    }
	                }

	                ComboBox {
	                    model: factions;
	                    current-index <=> faction_index;
	                }

	                // Weapon dropdown
	                HorizontalLayout {
	                    spacing: 8px;
	                    padding-top: 4px;
	                    Text {
	                        text: "Weapon:";
	                        color: Theme.text-secondary;
	                        font-size: 11px;
	                        vertical-alignment: center;
	                        width: 80px;
	                    }
	                }

	                ComboBox {
	                    model: entity_types;
	                    current-index <=> weapon_type_index;
	                }

	                HorizontalLayout {
	                    height: 24px;
	                    spacing: 8px;
	                    padding-top: 4px;
	                    CheckBox {
	                        text: "Include Weapon";
	                        checked <=> include_weapon;
	                    }
	                }

	                HorizontalLayout {
	                    height: 28px;
	                    spacing: 8px;
	                    LineEdit {
	                        width: 80px;
	                        text: base_speed == 0 ? "0.0" : base_speed;
	                        input-type: decimal;
	                    }

	                    Text {
	                        text: "Base Speed";
	                        color: Theme.text-secondary;
	                        font-size: 11px;
	                        vertical-alignment: center;
	                    }
	                }

	                HorizontalLayout {
	                    height: 24px;
	                    spacing: 8px;
	                    CheckBox {
	                        text: "Create Mode";
	                        checked <=> create_mode;
	                        toggled => {
	                            create_mode_changed(create_mode);
	                        }
	                    }
	                }
	            }
	        }
	    }
		}
	
			// ==================== PARTICLE EDITOR PANEL ====================
			if editor_visible: Panel {
			    x: parent.width - 430px;
			    y: 10px;
			    panel-width: 420px;
			    panel-height: particle_panel_expanded ? parent.height - 20px : 30px;
		
		    PanelHeader {
		        x: 8px;
		        y: 4px;
		        width: parent.width - 16px;
		        title: "Particle Editor";
		        expanded <=> particle_panel_expanded;
		    }
		
		    if particle_panel_expanded: ScrollView {
		        x: 0px;
		        y: 28px;
		        width: parent.width;
		        height: parent.height - 28px;
		
		        VerticalLayout {
		            padding: 8px;
		            spacing: 6px;
		
		            Text {
		                text: "Emitter Types";
		                color: Theme.text-secondary;
		                font-size: 11px;
		            }
		
		            ComboBox {
		                model: emitter_types;
		                current-index <=> emitter_type_index;
		            }
		
		            Rectangle {
		                height: 1px;
		                background: Theme.panel-border;
		            }
		
		            Text {
		                text: "Create a new Emitter";
		                color: Theme.text-secondary;
		                font-size: 11px;
		            }
		
		            LineEdit {
		                placeholder-text: "Staged Texture";
		                text <=> staged_texture;
		            }
		
		            Button {
		                text: "Use Staged Texture";
		                clicked => {
		                    pe_use_staged_texture_toggle = !pe_use_staged_texture_toggle;
		                }
		            }
		
		            LineEdit {
		                placeholder-text: "Emitter Name";
		                text <=> pe_emitter_name;
		            }
		
		            LabeledSlider {
		                label: "Position X";
		                minimum: -50.0;
		                maximum: 50.0;
		                value <=> pe_pos_x;
		            }
		            LabeledSlider {
		                label: "Position Y";
		                minimum: -50.0;
		                maximum: 50.0;
		                value <=> pe_pos_y;
		            }
		            LabeledSlider {
		                label: "Position Z";
		                minimum: -50.0;
		                maximum: 50.0;
		                value <=> pe_pos_z;
		            }
		
		            LabeledSlider {
		                label: "Direction X";
		                minimum: -1.0;
		                maximum: 1.0;
		                value <=> pe_dir_x;
		            }
		            LabeledSlider {
		                label: "Direction Y";
		                minimum: -1.0;
		                maximum: 1.0;
		                value <=> pe_dir_y;
		            }
		            LabeledSlider {
		                label: "Direction Z";
		                minimum: -1.0;
		                maximum: 1.0;
		                value <=> pe_dir_z;
		            }
		
		            LabeledSlider {
		                label: "Angle Min";
		                minimum: 0.0;
		                maximum: 6.28318;
		                value <=> pe_angle_min;
		            }
		            LabeledSlider {
		                label: "Angle Max";
		                minimum: 0.0;
		                maximum: 6.28318;
		                value <=> pe_angle_max;
		            }
		            LabeledSlider {
		                label: "Radius Min";
		                minimum: 0.0;
		                maximum: 20.0;
		                value <=> pe_radius_min;
		            }
		            LabeledSlider {
		                label: "Radius Max";
		                minimum: 0.0;
		                maximum: 20.0;
		                value <=> pe_radius_max;
		            }
		            LabeledSlider {
		                label: "Jitter Min";
		                minimum: 0.0;
		                maximum: 5.0;
		                value <=> pe_jitter_min;
		            }
		            LabeledSlider {
		                label: "Jitter Max";
		                minimum: 0.0;
		                maximum: 5.0;
		                value <=> pe_jitter_max;
		            }
		
		            LabeledSlider {
		                label: "Gravity";
		                minimum: -50.0;
		                maximum: 50.0;
		                value <=> pe_gravity;
		            }
		            LabeledSlider {
		                label: "Radial Speed Min";
		                minimum: 0.0;
		                maximum: 50.0;
		                value <=> pe_radial_speed_min;
		            }
		            LabeledSlider {
		                label: "Radial Speed Max";
		                minimum: 0.0;
		                maximum: 50.0;
		                value <=> pe_radial_speed_max;
		            }
		            LabeledSlider {
		                label: "Up Speed Min";
		                minimum: -10.0;
		                maximum: 10.0;
		                value <=> pe_up_speed_min;
		            }
		            LabeledSlider {
		                label: "Up Speed Max";
		                minimum: -10.0;
		                maximum: 10.0;
		                value <=> pe_up_speed_max;
		            }
		
		            LabeledSlider {
		                label: "Lifetime Min";
		                minimum: 0.0;
		                maximum: 5.0;
		                value <=> pe_lifetime_min;
		            }
		            LabeledSlider {
		                label: "Lifetime Max";
		                minimum: 0.0;
		                maximum: 5.0;
		                value <=> pe_lifetime_max;
		            }
		            LabeledSlider {
		                label: "Particle Count";
		                minimum: 1.0;
		                maximum: 500.0;
		                value <=> pe_particle_count;
		            }
		            LabeledSlider {
		                label: "PPS (continuous)";
		                minimum: 0.0;
		                maximum: 200.0;
		                value <=> pe_pps;
		            }
		
		            LabeledSlider {
		                label: "Color R";
		                minimum: 0.0;
		                maximum: 3.0;
		                value <=> pe_color_r;
		            }
		            LabeledSlider {
		                label: "Color G";
		                minimum: 0.0;
		                maximum: 3.0;
		                value <=> pe_color_g;
		            }
		            LabeledSlider {
		                label: "Color B";
		                minimum: 0.0;
		                maximum: 3.0;
		                value <=> pe_color_b;
		            }
		            LabeledSlider {
		                label: "Color A";
		                minimum: 0.0;
		                maximum: 1.0;
		                value <=> pe_color_a;
		            }
		
		            LabeledSlider {
		                label: "Start Alpha Min";
		                minimum: 0.0;
		                maximum: 2.0;
		                value <=> pe_base_alpha_min;
		            }
		            LabeledSlider {
		                label: "Start Alpha Max";
		                minimum: 0.0;
		                maximum: 2.0;
		                value <=> pe_base_alpha_max;
		            }
		            LabeledSlider {
		                label: "Alpha Multiplier";
		                minimum: 0.0;
		                maximum: 3.0;
		                value <=> pe_alpha_multiplier;
		            }
		            LabeledSlider {
		                label: "Alpha Curve (1=linear)";
		                minimum: 0.0;
		                maximum: 3.0;
		                value <=> pe_alpha_power;
		            }
		            LabeledSlider {
		                label: "Start Scale Min";
		                minimum: 0.0;
		                maximum: 1.0;
		                value <=> pe_base_scale_min;
		            }
		            LabeledSlider {
		                label: "Start Scale Max";
		                minimum: 0.0;
		                maximum: 1.0;
		                value <=> pe_base_scale_max;
		            }
		            LabeledSlider {
		                label: "Scale Multiplier";
		                minimum: 0.0;
		                maximum: 3.0;
		                value <=> pe_scale_multiplier;
		            }
		            LabeledSlider {
		                label: "Scale Curve (1=linear)";
		                minimum: 0.0;
		                maximum: 3.0;
		                value <=> pe_scale_power;
		            }
		
		            LineEdit {
		                placeholder-text: "Texture Path";
		                text <=> pe_texture_path;
		            }
		
		            CheckBox {
		                text: "Texture Has Alpha";
		                checked <=> pe_texture_has_alpha;
		            }
		
		            HorizontalLayout {
		                height: 28px;
		                spacing: 8px;
		                CheckBox {
		                    text: "Render Emitters";
		                    checked <=> pe_do_render;
		                }
		                Button {
		                    text: "Save";
		                    clicked => {
		                        pe_save_toggle = !pe_save_toggle;
		                    }
		                }
		            }
		        }
		    }
		}
	}
