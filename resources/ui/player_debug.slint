// Debug panel for the engine UI
import { VerticalBox, HorizontalBox } from "std-widgets.slint";

export component PlayerDebugPanel inherits Window {
    background: transparent;

    in property <string> position_text: "x: 0.0 y: 0.0 z: 0.0";
    in property <string> player_state_text: "Init";
    in property <string> attack_state_text: "Attack1";
    in property <string> current_animation_text: "Idle";
    in-out property <bool> panel_expanded: true;

    Rectangle {
        x: 10px;
        y: 10px;
        width: 320px;
        height: panel_expanded ? 140px : 30px;
        background: #1a1a2ecc;
        border-radius: 4px;
        border-width: 1px;
        border-color: #4a4a6a;

        VerticalLayout {
            padding: 8px;
            spacing: 4px;

            Rectangle {
                height: 20px;
                background: transparent;

                HorizontalLayout {
                    spacing: 8px;

                    Text {
                        text: panel_expanded ? "▼" : "▶";
                        color: #88aaff;
                        font-size: 12px;
                        vertical-alignment: center;
                    }

                    Text {
                        text: "Player Data";
                        color: #88aaff;
                        font-size: 14px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }

                TouchArea {
                    clicked => {
                        panel_expanded = !panel_expanded;
                    }
                }
            }

            if panel_expanded: VerticalLayout {
                spacing: 4px;
                padding-top: 4px;

                Text {
                    text: "Position: " + position_text;
                    color: white;
                    font-size: 12px;
                }

                Text {
                    text: "Player State: " + player_state_text;
                    color: white;
                    font-size: 12px;
                }

                Text {
                    text: "Attack State: " + attack_state_text;
                    color: white;
                    font-size: 12px;
                }

                Text {
                    text: "Current Animation: " + current_animation_text;
                    color: white;
                    font-size: 12px;
                }
            }
        }
    }
}

