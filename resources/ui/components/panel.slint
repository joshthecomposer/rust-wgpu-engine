// Panel container and header components
import { Theme } from "theme.slint";

// Panel container with consistent styling
export component Panel inherits Rectangle {
    in property <length> panel-width: 320px;
    in-out property <length> panel-height: 140px;
    
    width: panel-width;
    height: panel-height;
    background: Theme.panel-background;
    border-radius: 4px;
    border-width: 1px;
    border-color: Theme.panel-border;
}

// Collapsible panel header (for top-level panels)
export component PanelHeader inherits Rectangle {
    in property <string> title;
    in-out property <bool> expanded: true;
    
    height: 20px;
    background: transparent;
    
    HorizontalLayout {
        spacing: 8px;
        
        Text {
            text: expanded ? "▼" : "▶";
            color: Theme.accent;
            font-size: 12px;
            vertical-alignment: center;
        }
        Text {
            text: title;
            color: Theme.accent;
            font-size: 14px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }
    
    TouchArea {
        clicked => { expanded = !expanded; }
    }
}

