// section header for settings menu (e.g., "Display", "Interface", "Sound")
import { Theme } from "theme.slint";

export component RunicSettingsSectionHeader inherits Rectangle {
    in property <string> title;

    height: 24px;
    background: transparent;

    Text {
        text: title;
        color: Theme.runic-gold;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 3px;
        vertical-alignment: center;
    }

    // underline
    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.stone-light;
    }
}

