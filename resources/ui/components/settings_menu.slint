// settings menu tab content - all game settings
import { Theme } from "theme.slint";
import { RunicButton } from "menu_button.slint";
import { RunicSettingsSectionHeader } from "runic_settings_section_header.slint";
import { RunicSettingsRow } from "runic_settings_row.slint";
import { RunicCheckbox } from "runic_checkbox.slint";
import { RunicSlider } from "runic_slider.slint";
import { RunicSelect } from "runic_select.slint";
import { RunicMenuSeparator } from "runic_menu_separator.slint";
import { RunicScrollView } from "runic_scroll_view.slint";

export component SettingsMenu inherits Rectangle {
    // settings properties
    in-out property <string> resolution: "1920 x 1080";
    in-out property <string> window-mode: "Borderless";
    in-out property <bool> gizmo-enabled: false;
    in-out property <bool> show-fps: false;
    in-out property <float> bgm-volume: 100.0;
    in-out property <float> sfx-volume: 80.0;
    in-out property <bool> vsync: true;
    in-out property <bool> debug-mode: false;
    in-out property <string> msaa: "16x MSAA";

    callback apply_clicked();
    callback cancel_clicked();

    // dropdown positioning constants
    property <length> row-height: 32px;
    property <length> row-spacing: 12px;
    property <length> section-header-height: 28px;
    property <length> base-y: 60px; // starting Y position for first dropdown

    background: transparent;

    VerticalLayout {
        spacing: 0px;

        scroll-view := RunicScrollView {
            vertical-stretch: 1;
            viewport-height: 550px;

            VerticalLayout {
                spacing: 12px;
                padding-right: 8px;
                padding-bottom: 32px;

                    RunicSettingsSectionHeader {
                        title: "DISPLAY";
                    }

                    RunicSettingsRow {
                        label: "Resolution";
                        resolution-select := RunicSelect {
                            current-value: resolution;
                            options: ["1280 x 720", "1920 x 1080", "2560 x 1440"];
                            selected(value) => {
                                resolution = value;
                            }
                            opened => {
                                window-mode-select.is-open = false;
                                msaa-select.is-open = false;
                            }
                        }
                    }

                    RunicSettingsRow {
                        label: "Window Mode";
                        window-mode-select := RunicSelect {
                            current-value: window-mode;
                            options: ["Windowed", "Fullscreen", "Borderless"];
                            selected(value) => {
                                window-mode = value;
                            }
                            opened => {
                                resolution-select.is-open = false;
                            }
                        }
                    }

                    RunicSettingsRow {
                        label: "VSync";
                        RunicCheckbox {
                            checked: vsync;
                            toggled => {
                                vsync = !vsync;
                            }
                        }
                    }

                    RunicSettingsRow {
                        label: "MSAA";
                        msaa-select := RunicSelect {
                            current-value: msaa;
                            options: ["None", "2x MSAA", "4x MSAA", "8x MSAA", "16x MSAA"];
                            selected(value) => {
                                msaa = value;
                            }
                            opened => {
                                resolution-select.is-open = false;
                                window-mode-select.is-open = false;
                            }
                        }
                    }

                    RunicSettingsSectionHeader {
                        title: "INTERFACE";
                    }

                    RunicSettingsRow {
                        label: "Gizmo Rendering";
                        RunicCheckbox {
                            checked: gizmo-enabled;
                            toggled => {
                                gizmo-enabled = !gizmo-enabled;
                            }
                        }
                    }

                    RunicSettingsRow {
                        label: "Show FPS Counter";
                        RunicCheckbox {
                            checked: show-fps;
                            toggled => {
                                show-fps = !show-fps;
                            }
                        }
                    }

                    RunicSettingsRow {
                        label: "Debug Mode";
                        RunicCheckbox {
                            checked: debug-mode;
                            toggled => {
                                debug-mode = !debug-mode;
                            }
                        }
                    }

                    RunicSettingsSectionHeader {
                        title: "SOUND";
                    }

                    RunicSettingsRow {
                        label: "BGM Volume";
                        RunicSlider {
                            minimum: 0.0;
                            maximum: 100.0;
                            value: bgm-volume;
                            changed(v) => {
                                bgm-volume = v;
                            }
                        }
                    }

                    RunicSettingsRow {
                        label: "SFX Volume";
                        RunicSlider {
                            minimum: 0.0;
                            maximum: 100.0;
                            value: sfx-volume;
                            changed(v) => {
                                sfx-volume = v;
                            }
                        }
                    }
                }
            }

        RunicMenuSeparator { }

        HorizontalLayout {
            spacing: 12px;
            padding-top: 8px;

            RunicButton {
                label: "CANCEL";
                danger: true;
                clicked => { root.cancel_clicked(); }
            }

            RunicButton {
                label: "APPLY CHANGES";
                clicked => { root.apply_clicked(); }
            }
        }
    }

    // dropdown overlay layer - renders above everything
    // positioned manually based on layout

    // click-outside-to-close for resolution dropdown
    if resolution-select.is-open: TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            resolution-select.is-open = false;
        }
    }

    if resolution-select.is-open: Rectangle {
        x: root.width - 160px - 22px; // align to right side where dropdowns are (accounting for scrollbar)
        y: base-y; // first dropdown (section header + resolution row)
        width: 164px; // wider to accommodate border
        height: 3 * 28px + 4px; // taller to accommodate border
        background: Theme.stone-light; // subtle border
        drop-shadow-blur: 8px;
        drop-shadow-color: #00000080;
        drop-shadow-offset-y: 4px;

        // content background (inset to create border effect)
        Rectangle {
            x: 2px;
            y: 2px;
            width: parent.width - 4px;
            height: parent.height - 4px;
            background: #0f172a;

            VerticalLayout {
                padding: 0px;

                for option in ["1280 x 720", "1920 x 1080", "2560 x 1440"]: Rectangle {
                    height: 28px;
                    background: res-touch.has-hover ? Theme.stone-dark : #0f172a;

                    res-touch := TouchArea {
                        clicked => {
                            resolution = option;
                            resolution-select.is-open = false;
                        }
                    }

                    Text {
                        x: 12px;
                        text: option;
                        color: res-touch.has-hover ? Theme.runic-gold : Theme.old-text;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // click-outside-to-close for window mode dropdown
    if window-mode-select.is-open: TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            window-mode-select.is-open = false;
        }
    }

    if window-mode-select.is-open: Rectangle {
        x: root.width - 160px - 22px;
        y: base-y + row-height + row-spacing; // second dropdown (resolution + spacing)
        width: 164px; // wider to accommodate border
        height: 3 * 28px + 4px; // taller to accommodate border
        background: Theme.stone-light; // subtle border
        drop-shadow-blur: 8px;
        drop-shadow-color: #00000080;
        drop-shadow-offset-y: 4px;

        // content background (inset to create border effect)
        Rectangle {
            x: 2px;
            y: 2px;
            width: parent.width - 4px;
            height: parent.height - 4px;
            background: #0f172a;

            VerticalLayout {
                padding: 0px;

                for option in ["Windowed", "Fullscreen", "Borderless"]: Rectangle {
                    height: 28px;
                    background: wm-touch.has-hover ? Theme.stone-dark : #0f172a;

                    wm-touch := TouchArea {
                        clicked => {
                            window-mode = option;
                            window-mode-select.is-open = false;
                        }
                    }

                    Text {
                        x: 12px;
                        text: option;
                        color: wm-touch.has-hover ? Theme.runic-gold : Theme.old-text;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // click-outside-to-close for msaa dropdown
    if msaa-select.is-open: TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            msaa-select.is-open = false;
        }
    }

    if msaa-select.is-open: Rectangle {
        x: root.width - 160px - 22px;
        y: base-y + 3 * (row-height + row-spacing); // fourth dropdown (resolution + window-mode + vsync + spacing)
        width: 164px; // wider to accommodate border
        height: 5 * 28px + 4px; // taller to accommodate border (5 options)
        background: Theme.stone-light;
        drop-shadow-blur: 8px;
        drop-shadow-color: #00000080;
        drop-shadow-offset-y: 4px;

        // content background (inset to create border effect)
        Rectangle {
            x: 2px;
            y: 2px;
            width: parent.width - 4px;
            height: parent.height - 4px;
            background: #0f172a;

            VerticalLayout {
                padding: 0px;

                for option in ["None", "2x MSAA", "4x MSAA", "8x MSAA", "16x MSAA"]: Rectangle {
                    height: 28px;
                    background: msaa-touch.has-hover ? Theme.stone-dark : #0f172a;

                    msaa-touch := TouchArea {
                        clicked => {
                            debug("MSAA dropdown clicked:", option);
                            msaa = option;
                            debug("MSAA property set to:", msaa);
                            msaa-select.is-open = false;
                        }
                    }

                    Text {
                        x: 12px;
                        text: option;
                        color: msaa-touch.has-hover ? Theme.runic-gold : Theme.old-text;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

