// settings menu tab content - all game settings
import { Theme } from "theme.slint";
import { RunicButton } from "menu_button.slint";
import { RunicSettingsSectionHeader } from "runic_settings_section_header.slint";
import { RunicSettingsRow } from "runic_settings_row.slint";
import { RunicCheckbox } from "runic_checkbox.slint";
import { RunicSlider } from "runic_slider.slint";
import { RunicSelect } from "runic_select.slint";
import { RunicMenuSeparator } from "runic_menu_separator.slint";
import { RunicTabButton } from "runic_tab_button.slint";

export component SettingsMenu inherits Rectangle {
    // settings properties
    in-out property <string> resolution: "1920 x 1080";
    in-out property <string> window-mode: "Borderless";
    in-out property <bool> gizmo-enabled: false;
    in-out property <bool> show-fps: false;
    in-out property <float> bgm-volume: 100.0;
    in-out property <float> sfx-volume: 80.0;
    in-out property <bool> vsync: true;
    in-out property <bool> debug-mode: false;
    in-out property <string> msaa: "16x MSAA";
    in-out property <string> font-family: "Weiholmir";

    callback apply_clicked();
    callback cancel_clicked();

    // tab state: 0 = DISPLAY, 1 = INTERFACE, 2 = SOUND
    in-out property <int> active-settings-tab: 0;

    // dropdown state tracking
    private property <bool> resolution-dropdown-open: false;
    private property <bool> window-mode-dropdown-open: false;
    private property <bool> msaa-dropdown-open: false;
    private property <bool> font-dropdown-open: false;

    // dropdown positioning constants
    property <length> row-height: 32px;
    property <length> row-spacing: 12px;
    property <length> section-header-height: 28px;
    property <length> tab-content-top: 12px; // top of tab content area
    property <length> tab-header-height: 24px; // height of tab buttons area (smaller for secondary tabs)

    background: transparent;

    VerticalLayout {
        spacing: 0px;

        // tab buttons
        HorizontalLayout {
            width: parent.width;
            height: tab-header-height;
            spacing: 20px;
            alignment: center;

            RunicTabButton {
                label: "DISPLAY";
                active: active-settings-tab == 0;
                button-height: 24px;
                font-size: 11px;
                clicked => {
                    active-settings-tab = 0;
                    resolution-dropdown-open = false;
                    window-mode-dropdown-open = false;
                    msaa-dropdown-open = false;
                    font-dropdown-open = false;
                }
            }

            RunicTabButton {
                label: "INTERFACE";
                active: active-settings-tab == 1;
                button-height: 24px;
                font-size: 11px;
                clicked => {
                    active-settings-tab = 1;
                    resolution-dropdown-open = false;
                    window-mode-dropdown-open = false;
                    msaa-dropdown-open = false;
                    font-dropdown-open = false;
                }
            }

            RunicTabButton {
                label: "SOUND";
                active: active-settings-tab == 2;
                button-height: 24px;
                font-size: 11px;
                clicked => {
                    active-settings-tab = 2;
                    resolution-dropdown-open = false;
                    window-mode-dropdown-open = false;
                    msaa-dropdown-open = false;
                    font-dropdown-open = false;
                }
            }
        }

        // tab content container
        Rectangle {
            width: parent.width;
            vertical-stretch: 1;
            background: transparent;

            // DISPLAY tab content
            if active-settings-tab == 0: VerticalLayout {
                spacing: 12px;
                padding-right: 8px;
                padding-top: tab-content-top;

                RunicSettingsRow {
                    label: "Resolution";
                    resolution-select := RunicSelect {
                        is-open <=> root.resolution-dropdown-open;
                        current-value: resolution;
                        options: ["1280 x 720", "1920 x 1080", "2560 x 1440"];
                        selected(value) => {
                            resolution = value;
                        }
                        opened => {
                            window-mode-dropdown-open = false;
                            msaa-dropdown-open = false;
                            font-dropdown-open = false;
                        }
                    }
                }

                RunicSettingsRow {
                    label: "Window Mode";
                    window-mode-select := RunicSelect {
                        is-open <=> root.window-mode-dropdown-open;
                        current-value: window-mode;
                        options: ["Windowed", "Fullscreen", "Borderless"];
                        selected(value) => {
                            window-mode = value;
                        }
                        opened => {
                            resolution-dropdown-open = false;
                            font-dropdown-open = false;
                        }
                    }
                }

                RunicSettingsRow {
                    label: "VSync";
                    RunicCheckbox {
                        checked: vsync;
                        toggled => {
                            vsync = !vsync;
                        }
                    }
                }

                RunicSettingsRow {
                    label: "MSAA";
                    msaa-select := RunicSelect {
                        is-open <=> root.msaa-dropdown-open;
                        current-value: msaa;
                        options: ["None", "2x MSAA", "4x MSAA", "8x MSAA", "16x MSAA"];
                        selected(value) => {
                            msaa = value;
                        }
                        opened => {
                            resolution-dropdown-open = false;
                            window-mode-dropdown-open = false;
                            font-dropdown-open = false;
                        }
                    }
                }
            }

            // INTERFACE tab content
            if active-settings-tab == 1: VerticalLayout {
                spacing: 12px;
                padding-right: 8px;
                padding-top: tab-content-top;

                RunicSettingsRow {
                    label: "Gizmo Rendering";
                    RunicCheckbox {
                        checked: gizmo-enabled;
                        toggled => {
                            gizmo-enabled = !gizmo-enabled;
                        }
                    }
                }

                RunicSettingsRow {
                    label: "Show FPS Counter";
                    RunicCheckbox {
                        checked: show-fps;
                        toggled => {
                            show-fps = !show-fps;
                        }
                    }
                }

                RunicSettingsRow {
                    label: "Debug Mode";
                    RunicCheckbox {
                        checked: debug-mode;
                        toggled => {
                            debug-mode = !debug-mode;
                        }
                    }
                }

                RunicSettingsRow {
                    label: "Font";
                    font-select := RunicSelect {
                        is-open <=> root.font-dropdown-open;
                        current-value: font-family;
                        options: ["Weiholmir", "JetBrains Mono", "OpenDyslexic"];
                        selected(value) => {
                            font-family = value;
                        }
                        opened => {
                            resolution-dropdown-open = false;
                            window-mode-dropdown-open = false;
                            msaa-dropdown-open = false;
                        }
                    }
                }
            }

            // SOUND tab content
            if active-settings-tab == 2: VerticalLayout {
                spacing: 12px;
                padding-right: 8px;
                padding-top: tab-content-top;

                RunicSettingsRow {
                    label: "BGM Volume";
                    RunicSlider {
                        minimum: 0.0;
                        maximum: 100.0;
                        value: bgm-volume;
                        changed(v) => {
                            bgm-volume = v;
                        }
                    }
                }

                RunicSettingsRow {
                    label: "SFX Volume";
                    RunicSlider {
                        minimum: 0.0;
                        maximum: 100.0;
                        value: sfx-volume;
                        changed(v) => {
                            sfx-volume = v;
                        }
                    }
                }
            }
        }

        RunicMenuSeparator { }

        HorizontalLayout {
            spacing: 12px;
            padding-top: 8px;

            RunicButton {
                label: "CANCEL";
                danger: true;
                clicked => { root.cancel_clicked(); }
            }

            RunicButton {
                label: "APPLY CHANGES";
                clicked => { root.apply_clicked(); }
            }
        }
    }

    // dropdown overlay layer - renders above everything
    // positioned manually based on layout

    // click-outside-to-close for resolution dropdown
    if resolution-dropdown-open && active-settings-tab == 0: TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            resolution-dropdown-open = false;
        }
    }

    if resolution-dropdown-open && active-settings-tab == 0: Rectangle {
        x: root.width - 160px - 8px; // align to right side where dropdowns are
        y: tab-header-height + tab-content-top + row-height; // first row in DISPLAY tab
        width: 164px; // wider to accommodate border
        height: 3 * 28px + 4px; // taller to accommodate border
        background: Theme.stone-light; // subtle border
        drop-shadow-blur: 8px;
        drop-shadow-color: #00000080;
        drop-shadow-offset-y: 4px;

        // content background (inset to create border effect)
        Rectangle {
            x: 2px;
            y: 2px;
            width: parent.width - 4px;
            height: parent.height - 4px;
            background: #0f172a;

            VerticalLayout {
                padding: 0px;

                for option in ["1280 x 720", "1920 x 1080", "2560 x 1440"]: Rectangle {
                    height: 28px;
                    background: res-touch.has-hover ? Theme.stone-dark : #0f172a;

                    res-touch := TouchArea {
                        clicked => {
                            resolution = option;
                            resolution-dropdown-open = false;
                        }
                    }

                    Text {
                        x: 12px;
                        text: option;
                        color: res-touch.has-hover ? Theme.runic-gold : Theme.old-text;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // click-outside-to-close for window mode dropdown
    if window-mode-dropdown-open && active-settings-tab == 0: TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            window-mode-dropdown-open = false;
        }
    }

    if window-mode-dropdown-open && active-settings-tab == 0: Rectangle {
        x: root.width - 160px - 8px;
        y: tab-header-height + tab-content-top + row-height + row-spacing + row-height; // second row in DISPLAY tab
        width: 164px; // wider to accommodate border
        height: 3 * 28px + 4px; // taller to accommodate border
        background: Theme.stone-light; // subtle border
        drop-shadow-blur: 8px;
        drop-shadow-color: #00000080;
        drop-shadow-offset-y: 4px;

        // content background (inset to create border effect)
        Rectangle {
            x: 2px;
            y: 2px;
            width: parent.width - 4px;
            height: parent.height - 4px;
            background: #0f172a;

            VerticalLayout {
                padding: 0px;

                for option in ["Windowed", "Fullscreen", "Borderless"]: Rectangle {
                    height: 28px;
                    background: wm-touch.has-hover ? Theme.stone-dark : #0f172a;

                    wm-touch := TouchArea {
                        clicked => {
                            window-mode = option;
                            window-mode-dropdown-open = false;
                        }
                    }

                    Text {
                        x: 12px;
                        text: option;
                        color: wm-touch.has-hover ? Theme.runic-gold : Theme.old-text;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // click-outside-to-close for msaa dropdown
    if msaa-dropdown-open && active-settings-tab == 0: TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            msaa-dropdown-open = false;
        }
    }

    if msaa-dropdown-open && active-settings-tab == 0: Rectangle {
        x: root.width - 160px - 8px;
        y: tab-header-height + tab-content-top + 3 * (row-height + row-spacing) + row-height; // fourth row in DISPLAY tab
        width: 164px; // wider to accommodate border
        height: 5 * 28px + 4px; // taller to accommodate border (5 options)
        background: Theme.stone-light;
        drop-shadow-blur: 8px;
        drop-shadow-color: #00000080;
        drop-shadow-offset-y: 4px;

        // content background (inset to create border effect)
        Rectangle {
            x: 2px;
            y: 2px;
            width: parent.width - 4px;
            height: parent.height - 4px;
            background: #0f172a;

            VerticalLayout {
                padding: 0px;

                for option in ["None", "2x MSAA", "4x MSAA", "8x MSAA", "16x MSAA"]: Rectangle {
                    height: 28px;
                    background: msaa-touch.has-hover ? Theme.stone-dark : #0f172a;

                    msaa-touch := TouchArea {
                        clicked => {
                            debug("MSAA dropdown clicked:", option);
                            msaa = option;
                            debug("MSAA property set to:", msaa);
                            msaa-dropdown-open = false;
                        }
                    }

                    Text {
                        x: 12px;
                        text: option;
                        color: msaa-touch.has-hover ? Theme.runic-gold : Theme.old-text;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // click-outside-to-close for font dropdown
    if font-dropdown-open && active-settings-tab == 1: TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            font-dropdown-open = false;
        }
    }

    if font-dropdown-open && active-settings-tab == 1: Rectangle {
        x: root.width - 240px - 8px; // dropdown for font names
        y: tab-header-height + tab-content-top + 3 * (row-height + row-spacing) + row-height; // fourth row in INTERFACE tab
        width: 244px; // wide enough to fit "JetBrains Mono"
        height: 3 * 28px + 4px; // taller to accommodate border (3 font options)
        background: Theme.stone-light;
        drop-shadow-blur: 8px;
        drop-shadow-color: #00000080;
        drop-shadow-offset-y: 4px;

        // content background (inset to create border effect)
        Rectangle {
            x: 2px;
            y: 2px;
            width: parent.width - 4px;
            height: parent.height - 4px;
            background: #0f172a;

            VerticalLayout {
                padding: 0px;

                for option in ["Weiholmir", "JetBrains Mono", "OpenDyslexic"]: Rectangle {
                    height: 28px;
                    background: font-touch.has-hover ? Theme.stone-dark : #0f172a;

                    font-touch := TouchArea {
                        clicked => {
                            font-family = option;
                            font-dropdown-open = false;
                        }
                    }

                    Text {
                        x: 12px;
                        text: option;
                        color: font-touch.has-hover ? Theme.runic-gold : Theme.old-text;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

