// runic-styled menu button for game UI (pause menu)
import { Theme } from "theme.slint";

// keep old MenuButton for backwards compatibility
export component MenuButton inherits Rectangle {
    in property <string> label;
    callback clicked();

    height: 50px;
    background: touch.has-hover ? Theme.stone-mild : Theme.stone-dark;
    border-radius: 4px;
    border-width: 1px;
    border-color: Theme.stone-light;

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        text: label;
        color: Theme.highlight;
        font-size: 14px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// new runic-styled button with hard shadow and hover effects
export component RunicButton inherits Rectangle {
    in property <string> label;
    in property <bool> danger: false;
    callback clicked();

    height: 52px;
    background: transparent;

    // hard shadow (offset behind)
    Rectangle {
        x: 4px;
        y: 4px;
        width: parent.width - 4px;
        height: parent.height - 4px;
        background: #000000.with-alpha(0.5);
    }

    // main button
    Rectangle {
        x: touch.pressed ? 2px : (touch.has-hover ? -1px : 0);
        y: touch.pressed ? 2px : (touch.has-hover ? -1px : 0);
        width: parent.width - 4px;
        height: parent.height - 4px;
        background: touch.has-hover ?
            (danger ? #450a0a : Theme.stone-mild) :
            Theme.stone-dark;
        border-width: 1px;
        border-color: touch.has-hover ?
            (danger ? #7f1d1d : Theme.stone-edge) :
            Theme.stone-light;

        // side decorations (bullets)
        Text {
            x: 12px;
            text: "•";
            color: touch.has-hover ? Theme.runic-gold : transparent;
            font-size: 14px;
            vertical-alignment: center;
        }
        Text {
            x: parent.width - 20px;
            text: "•";
            color: touch.has-hover ? Theme.runic-gold : transparent;
            font-size: 14px;
            vertical-alignment: center;
        }

        // button label
        Text {
            text: label;
            color: touch.has-hover ?
                (danger ? #fca5a5 : Theme.highlight) :
                Theme.old-text;
            font-size: 13px;
            letter-spacing: 1.5px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

