// player container HUD component - shows portrait, name, level, HP and mana bars
import { Theme } from "theme.slint";

component StatBar inherits Rectangle {
    in property <float> current: 0;
    in property <float> maximum: 100;
    in property <color> bar-color: Theme.blood-hp;
    
    height: 18px;
    background: Theme.deep-void;
    border-radius: 2px;
    border-width: 1px;
    border-color: Theme.stone-light;
    
    // fill bar
    Rectangle {
        x: 2px;
        y: 2px;
        width: max(0px, (parent.width - 4px) * clamp(current / maximum, 0, 1));
        height: parent.height - 4px;
        background: bar-color;
        border-radius: 1px;
    }
    
    // value text
    Text {
        width: parent.width;
        height: parent.height;
        text: round(current) + " / " + round(maximum);
        color: Theme.highlight;
        font-size: 11px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component PlayerContainer inherits Rectangle {
    in property <string> player-name: "UNKNOWN";
    in property <int> level: 1;
    in property <float> health-current: 100;
    in property <float> health-max: 100;
    in property <float> mana-current: 100;
    in property <float> mana-max: 100;
    in property <bool> show-hud: true;

    width: 280px;
    height: 90px;
    background: transparent;

    if show-hud: Rectangle {
        width: parent.width;
        height: parent.height;
        background: Theme.deep-void.with-alpha(0.85);
        border-radius: 4px;
        border-width: 1px;
        border-color: Theme.stone-light;
        
        HorizontalLayout {
            padding: 8px;
            spacing: 12px;
            
            // portrait frame (diamond shape placeholder)
            VerticalLayout {
                alignment: center;
                spacing: 4px;
                
                // portrait frame - transparent to let GL-rendered portrait show through
                Rectangle {
                    width: 56px;
                    height: 56px;
                    background: Colors.transparent;
                    border-width: 2px;
                    border-color: Theme.runic-gold;
                }
                
                // level display
                Text {
                    horizontal-alignment: center;
                    text: "LV " + level;
                    color: Theme.runic-gold;
                    font-size: 10px;
                    font-weight: 700;
                }
            }
            
            // name and bars
            VerticalLayout {
                alignment: center;
                spacing: 6px;
                
                // player name
                Text {
                    text: player-name;
                    color: Theme.highlight;
                    font-size: 14px;
                    font-weight: 700;
                    letter-spacing: 2px;
                }
                
                // HP bar
                StatBar {
                    current: health-current;
                    maximum: health-max;
                    bar-color: Theme.blood-hp;
                }
                
                // mana bar
                StatBar {
                    current: mana-current;
                    maximum: mana-max;
                    bar-color: Theme.mana-sky;
                }
            }
        }
    }
}

