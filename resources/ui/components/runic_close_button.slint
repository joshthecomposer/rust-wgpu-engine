// close button used in runic windows ("×" icon with hover color)
import { Theme } from "theme.slint";

export component RunicCloseButton inherits Rectangle {
    in property <length> size: 20px;
    callback clicked();

    width: size;
    height: size;
    background: transparent;

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        width: parent.width;
        text: "×";
        color: touch.has-hover ? Theme.runic-gold : Theme.stone-light;
        font-size: 18px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

