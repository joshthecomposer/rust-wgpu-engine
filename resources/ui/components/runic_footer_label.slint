// footer label used for build/version text in runic menus
import { Theme } from "theme.slint";

export component RunicFooterLabel inherits Text {
    in property <string> prefix: "BUILD ";
    in property <string> value: "v0.0.1a";

    text: prefix + value;
    color: Theme.muted-scrawl;
    font-size: 10px;
    letter-spacing: 2px;
    horizontal-alignment: center;
}

