// Collapsible section header component
import { Theme } from "theme.slint";

export component SectionHeader inherits Rectangle {
    in property <string> title;
    in-out property <bool> expanded: true;
    
    height: 24px;
    background: Theme.section-background;
    border-radius: 2px;
    
    HorizontalLayout {
        padding-left: 8px;
        spacing: 8px;
        
        Text {
            text: expanded ? "▼" : "▶";
            color: Theme.accent;
            font-size: 10px;
            vertical-alignment: center;
        }
        Text {
            text: title;
            color: Theme.accent;
            font-size: 12px;
            font-weight: 600;
            vertical-alignment: center;
        }
    }
    
    TouchArea {
        clicked => { expanded = !expanded; }
    }
}

