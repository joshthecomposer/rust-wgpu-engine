// centered runic window header with underline and diamond decoration
import { Theme } from "theme.slint";

export component RunicWindowHeader inherits VerticalLayout {
    in property <string> title;

	    // width is provided by the parent when this header is instantiated
    alignment: start;
    spacing: 0;

    Text {
        width: parent.width;
        text: title;
        color: Theme.highlight;
        font-size: 18px;
        font-weight: 700;
        letter-spacing: 4px;
        horizontal-alignment: center;
    }

    // spacer between title and underline
    Rectangle {
        height: 8px;
        background: transparent;
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        height: 1px;
        width: 160px;
        background: Theme.stone-light;
    }

    Rectangle {
        height: 16px;
        Text {
            width: parent.width;
            text: "◆";
            color: Theme.runic-gold;
            font-size: 10px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

