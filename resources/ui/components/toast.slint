// toast notification component with slide-in and fade-out animations
import { Theme } from "theme.slint";

export component Toast inherits Rectangle {
    in property <int> toast-type; // 0=Success, 1=Error, 2=Warning, 3=Info
    in property <string> title;
    in property <string> message;
    in property <int> toast-id;
    in property <int> state; // 0=entering, 1=visible, 2=exiting
    callback close-clicked(int);

    width: 100%;
    height: content-layout.preferred-height + 32px;
    background: transparent;
    clip: false;

    // determine colors based on toast type
    property <color> accent-color: toast-type == 0 ? Theme.runic-gold :
                                    toast-type == 1 ? Theme.blood-hp :
                                    toast-type == 2 ? Theme.icon-glow :
                                    Theme.mana-sky;
    
    property <string> icon-text: toast-type == 0 ? "✦" :
                                  toast-type == 1 ? "✖" :
                                  toast-type == 2 ? "⚠" :
                                  "ℹ";

    // hard shadow (offset behind)
    shadow := Rectangle {
        x: 4px;
        y: 4px;
        width: parent.width;
        height: parent.height;
        background: #000000.with-alpha(0.5);

        animate x, opacity {
            duration: 300ms;
            easing: ease-out;
        }
    }

    // main toast body
    body := Rectangle {
        width: parent.width;
        height: parent.height;
        background: @linear-gradient(90deg, Theme.stone-dark 0%, Theme.deep-void 100%);
        border-width: 1px;
        border-color: Theme.stone-light;
        clip: false;

        animate x, opacity {
            duration: 300ms;
            easing: ease-out;
        }

        // horizontal layout containing accent bar and content
        HorizontalLayout {
            spacing: 0;

            // left accent bar (4px wide)
            Rectangle {
                width: 4px;
                background: accent-color;
            }

            // content layout
            content-layout := HorizontalLayout {
                padding-left: 12px;
                padding-right: 16px;
                padding-top: 12px;
                padding-bottom: 12px;
                spacing: 10px;
                alignment: start;

            // icon container - explicit size to prevent clipping
            Rectangle {
                width: 32px;
                height: 32px;
                background: transparent;
                clip: false;

                Text {
                    width: 100%;
                    height: 100%;
                    text: icon-text;
                    color: accent-color;
                    font-size: 22px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            // title and message
            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: title;
                    color: Theme.highlight;
                    font-size: 14px;
                    font-weight: 700;
                    letter-spacing: 0.5px;
                    wrap: word-wrap;
                }

                Text {
                    text: message;
                    color: Theme.old-text;
                    font-size: 13px;
                    wrap: word-wrap;
                }
            }

                // close button
                close-btn := Rectangle {
                    width: 20px;
                    height: 20px;
                    background: transparent;

                    touch := TouchArea {
                        clicked => { root.close-clicked(toast-id); }
                    }

                    Text {
                        text: "×";
                        color: touch.has-hover ? Theme.old-text : Theme.stone-light;
                        font-size: 20px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // animation states
    states [
        entering when state == 0: {
            body.x: root.width; // off-screen to the right
            body.opacity: 0;
            shadow.x: root.width + 4px;
            shadow.opacity: 0;
        }
        exiting when state == 2: {
            body.opacity: 0;
            shadow.opacity: 0;
        }
    ]
}

