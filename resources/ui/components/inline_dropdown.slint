// Custom dropdown that works with software renderer (no popup)
import { Theme } from "theme.slint";

export component InlineDropdown inherits Rectangle {
    in property <[string]> model: [];
    in-out property <int> current-index: 0;
    in-out property <bool> expanded: false;
    in property <length> dropdown-width: 180px;
    callback selected(int);

    width: dropdown-width;
    height: expanded ? (28px + model.length * 24px) : 28px;

    header := Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: 28px;
        background: Theme.dropdown-background;
        border-radius: 4px;
        border-width: 1px;
        border-color: expanded ? Theme.accent : Theme.border-normal;

        Text {
            x: 8px;
            text: model.length > 0 && current-index >= 0 && current-index < model.length ? model[current-index] : "";
            color: Theme.text-primary;
            font-size: 11px;
            vertical-alignment: center;
        }
        Text {
            x: parent.width - 24px;
            width: 16px;
            text: expanded ? "▲" : "▼";
            color: Theme.accent;
            font-size: 10px;
            vertical-alignment: center;
        }

        TouchArea {
            clicked => { expanded = !expanded; }
        }
    }

    if expanded: Rectangle {
        x: 0;
        y: 28px;
        width: parent.width;
        height: model.length * 24px;
        background: Theme.section-background;
        border-width: 1px;
        border-color: Theme.border-normal;

        for item[idx] in model: Rectangle {
            x: 0;
            y: idx * 24px;
            width: parent.width;
            height: 24px;
            background: idx == current-index ? Theme.dropdown-item-selected : (item-touch.has-hover ? Theme.dropdown-item-hover : transparent);

            Text {
                x: 8px;
                text: item;
                color: idx == current-index ? Theme.accent : Theme.text-primary;
                font-size: 11px;
                vertical-alignment: center;
            }

            item-touch := TouchArea {
                width: 100%;
                height: 100%;
                clicked => {
                    current-index = idx;
                    expanded = false;
                    selected(idx);
                }
            }
        }
    }
}

