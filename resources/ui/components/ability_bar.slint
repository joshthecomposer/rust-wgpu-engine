// ability bar component - shows 6 ability slots (M1, M2, Q, E, Shift, R)
import { Theme } from "theme.slint";

// data model for a single ability slot
export struct AbilitySlotData {
    visible: bool,
    ability-id: int,
    key-label: string,
    cooldown-progress: float, // 0.0 = ready, 1.0 = full cooldown
    cooldown-time-remaining: float, // time in seconds until ready
    is-ready: bool,
}

// single ability slot component
component AbilitySlot inherits Rectangle {
    in property <AbilitySlotData> data;
    
    width: 48px;
    height: 48px;
    background: Theme.deep-void.with-alpha(0.9);
    border-radius: 4px;
    border-width: 1px;
    border-color: data.is-ready ? Theme.runic-gold : Theme.stone-light;
    
    // ability icon/number display
    Text {
        width: 100%;
        height: 100%;
        text: data.ability-id > 0 ? data.ability-id : "-";
        color: data.is-ready ? Theme.highlight : Theme.old-text;
        font-size: 18px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    
    // cooldown overlay
    if data.cooldown-progress > 0: Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height * data.cooldown-progress;
        background: #000000.with-alpha(0.6);
        border-radius: parent.border-radius;
    }
    
    // key label
    Rectangle {
        x: parent.width - self.width - 2px;
        y: 2px;
        width: key-text.preferred-width + 6px;
        height: 14px;
        background: Theme.stone-dark;
        border-radius: 2px;
        
        key-text := Text {
            width: 100%;
            height: 100%;
            text: data.key-label;
            color: Theme.old-text;
            font-size: 9px;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
    
    // ready glow effect
    if data.is-ready && data.cooldown-progress == 0: Rectangle {
        x: -2px;
        y: -2px;
        width: parent.width + 4px;
        height: parent.height + 4px;
        background: transparent;
        border-radius: 6px;
        border-width: 1px;
        border-color: Theme.runic-gold.with-alpha(0.5);
    }
}

export component AbilityBar inherits Rectangle {
    in property <bool> show: true;

    // slot data for each ability (M1, M2, Q, E, Shift, R)
    in property <AbilitySlotData> slot-m1: { visible: true, ability-id: 0, key-label: "M1", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true };
    in property <AbilitySlotData> slot-m2: { visible: true, ability-id: 0, key-label: "M2", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true };
    in property <AbilitySlotData> slot-q: { visible: true, ability-id: 0, key-label: "Q", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true };
    in property <AbilitySlotData> slot-e: { visible: true, ability-id: 0, key-label: "E", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true };
    in property <AbilitySlotData> slot-shift: { visible: true, ability-id: 0, key-label: "Shift", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true };
    in property <AbilitySlotData> slot-r: { visible: true, ability-id: 0, key-label: "R", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true };

    // calculate width based on visible slots (6 slots * 48px + 5 gaps * 6px + 2 separators * 8px + padding)
    width: show ? 380px : 0px;
    height: show ? 68px : 0px;
    background: transparent;

    if show: Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.deep-void.with-alpha(0.7);
        border-radius: 6px;
        border-width: 1px;
        border-color: Theme.stone-light;

        HorizontalLayout {
            padding: 8px;
            spacing: 6px;
            alignment: center;

            if slot-m1.visible: AbilitySlot { data: slot-m1; }

            if slot-m2.visible: AbilitySlot { data: slot-m2; }

            // separator
            Rectangle { width: 8px; }

            if slot-q.visible: AbilitySlot { data: slot-q; }

            if slot-e.visible: AbilitySlot { data: slot-e; }

            if slot-shift.visible: AbilitySlot { data: slot-shift; }

            Rectangle { width: 8px; }

            if slot-r.visible: AbilitySlot { data: slot-r; }
        }
    }
}

