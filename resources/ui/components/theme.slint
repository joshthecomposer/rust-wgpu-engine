// Theme constants for consistent styling across UI components

export global Theme {
    out property <color> panel-background: #1a1a2ecc;
    out property <color> panel-background-solid: #1a1a2eee;
    out property <color> panel-border: #4a4a6a;
    out property <color> section-background: #2a2a4a;
    out property <color> dropdown-background: #3a3a5a;
    out property <color> dropdown-item-hover: #3a3a6a;
    out property <color> dropdown-item-selected: #4a4a8a;
    out property <color> accent: #88aaff;
    out property <color> text-primary: white;
    out property <color> text-secondary: #aaaaaa;
    out property <color> border-normal: #5a5a7a;
}

