// Theme constants for consistent styling across UI components
export global Theme {
    out property <color> panel-background: #d8d4c4;
    out property <color> panel-background-solid: #e6e2d0;
    out property <color> panel-border: #5a4a3a;
    out property <color> section-background: #c6c2b0;
    out property <color> dropdown-background: #e6e2d0;
    out property <color> dropdown-item-hover: #b8a494;
    out property <color> dropdown-item-selected: #8a2a2a;
    out property <color> accent: #aa3333;
    out property <color> text-primary: #1a0a0a;
    out property <color> text-secondary: #5a4a4a;
    out property <color> border-normal: #8a7a6a;
}
