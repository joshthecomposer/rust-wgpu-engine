// Theme constants for consistent styling across UI components
export global Theme {
    // ==================== LIGHT THEME (Engine UI) ====================
    out property <color> panel-background: #d8d4c4;
    out property <color> panel-background-solid: #e6e2d0;
    out property <color> panel-border: #5a4a3a;
    out property <color> section-background: #c6c2b0;
    out property <color> dropdown-background: #e6e2d0;
    out property <color> dropdown-item-hover: #b8a494;
    out property <color> dropdown-item-selected: #8a2a2a;
    out property <color> accent: #aa3333;
    out property <color> text-primary: #1a0a0a;
    out property <color> text-secondary: #5a4a4a;
    out property <color> border-normal: #8a7a6a;

    // ==================== DARK THEME (Game UI) ====================
    out property <color> dark-panel-background: #030712;
    out property <color> dark-panel-background-solid: #0a0f1a;
    out property <color> dark-panel-border: #374151;
    out property <color> dark-section-background: #1c1917;
    out property <color> dark-dropdown-background: #1f2937;
    out property <color> dark-dropdown-item-hover: #374151;
    out property <color> dark-dropdown-item-selected: #dc2626;
    out property <color> dark-accent: #f87171;
    out property <color> dark-text-primary: #f9fafb;
    out property <color> dark-text-secondary: #9ca3af;
    out property <color> dark-border-normal: #4b5563;

    // ==================== DESIGN SYSTEM COLORS ====================
    // backgrounds
    out property <color> deep-void: #0f172a;
    // containers
    out property <color> stone-dark: #1e293b;
    // secondary color
    out property <color> stone-mild: #334155;
    // borders
    out property <color> stone-light: #475569;
    // accents
    out property <color> stone-edge: #64748b;
    // body text
    out property <color> old-text: #94a3b8;
    // secondary text
    out property <color> muted-scrawl: #78716c;
    // header text
    out property <color> highlight: #fef3c7;
    // buttons / active
    out property <color> runic-gold: #d97706;
    // xp and icon glow
    out property <color> icon-glow: #d97706;
    // hp / health bar
    out property <color> blood-hp: #991b1b;
    // mana
    out property <color> mana-sky: #075985;

    // ==================== RARITY COLORS ====================
    // common
    out property <color> common-bone: #e2e8f0;
    // uncommon
    out property <color> uncommon-moss: #a3e635;
    // rare
    out property <color> rare-amethyst: #c084fc;
    // epic
    out property <color> epic-jade: #2dd4bf;
    // legendary
    out property <color> legendary-gold: #fcd34d;
}
