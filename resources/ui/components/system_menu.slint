// system menu tab content - game actions like reload, save, quit
import { RunicButton } from "menu_button.slint";
import { RunicMenuSeparator } from "runic_menu_separator.slint";

export component SystemMenu inherits Rectangle {
    callback reload_world_clicked();
    callback save_player_clicked();
    callback quit_clicked();

    background: transparent;

    VerticalLayout {
        spacing: 16px;

        RunicButton {
            label: "RELOAD WORLD DATA";
            clicked => { root.reload_world_clicked(); }
        }

        RunicButton {
            label: "SAVE PLAYER DATA";
            clicked => { root.save_player_clicked(); }
        }

        RunicMenuSeparator { }

        RunicButton {
            label: "QUIT GAME";
            danger: true;
            clicked => { root.quit_clicked(); }
        }
    }
}

