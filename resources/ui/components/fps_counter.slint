// FPS counter display for top-right corner
import { Theme } from "theme.slint";

export component FpsCounter inherits Rectangle {
    in property <int> fps: 60;
    in property <bool> show: true;

    width: 80px;
    height: 32px;
    background: transparent;

    if show: Rectangle {
        width: parent.width;
        height: parent.height;
        background: Theme.deep-void.with-alpha(0.7);
        border-width: 1px;
        border-color: Theme.stone-light;

        VerticalLayout {
            padding: 4px;
            spacing: 2px;

            Text {
                text: "FPS";
                color: Theme.muted-scrawl;
                font-size: 9px;
                letter-spacing: 1px;
                horizontal-alignment: center;
            }

            Text {
                text: fps;
                color: Theme.highlight;
                font-size: 14px;
                font-weight: 700;
                horizontal-alignment: center;
            }
        }
    }
}

