// runic-styled checkbox with interior glow when checked
import { Theme } from "theme.slint";

export component RunicCheckbox inherits Rectangle {
    in-out property <bool> checked: false;
    callback toggled();

    width: 18px;
    height: 18px;
    background: Theme.stone-dark;
    border-width: 1px;
    border-color: touch.has-hover ? Theme.runic-gold : Theme.stone-light;

    touch := TouchArea {
        clicked => {
            checked = !checked;
            root.toggled();
        }
    }

    // checkmark (filled square when checked)
    if checked: Rectangle {
        x: 4px;
        y: 4px;
        width: parent.width - 8px;
        height: parent.height - 8px;
        background: Theme.runic-gold;
    }
}

