// Labeled slider with value display
import { Slider } from "std-widgets.slint";
import { Theme } from "theme.slint";

export component LabeledSlider inherits Rectangle {
    in property <string> label;
    in property <float> minimum: 0.0;
    in property <float> maximum: 1.0;
    in-out property <float> value: 0.0;
    callback changed(float);
    
    height: 24px;
    background: transparent;
    
    HorizontalLayout {
        spacing: 8px;
        
        Slider {
            width: 150px;
            minimum: root.minimum;
            maximum: root.maximum;
            value <=> root.value;
            changed(v) => { root.changed(v); }
        }
        Text {
            text: root.value >= 0 ? " " + root.value : root.value;
            color: Theme.text-primary;
            font-size: 11px;
            vertical-alignment: center;
            min-width: 60px;
        }
        Text {
            text: label;
            color: Theme.text-secondary;
            font-size: 11px;
            vertical-alignment: center;
        }
    }
}

