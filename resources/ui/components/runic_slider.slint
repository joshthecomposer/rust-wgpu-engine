// runic-styled slider with diamond thumb
import { Theme } from "theme.slint";

export component RunicSlider inherits Rectangle {
    in property <float> minimum: 0.0;
    in property <float> maximum: 100.0;
    in-out property <float> value: 50.0;
    callback changed(float);

    width: 150px;
    height: 20px;
    background: transparent;

    // track background
    track := Rectangle {
        y: (parent.height - self.height) / 2;
        width: parent.width;
        height: 6px;
        background: #000000;
        border-width: 1px;
        border-color: Theme.stone-light;
    }

    thumb := Rectangle {
        property <float> normalized: (value - minimum) / (maximum - minimum);
        x: (parent.width - self.width) * clamp(normalized, 0, 1);
        y: (parent.height - self.height) / 2;
        width: 16px;
        height: 16px;
        background: touch.pressed ? Theme.icon-glow : Theme.runic-gold;
        border-width: 1px;
        border-color: #000000;
    }

    touch := TouchArea {
        property <float> pressed-value;

        pointer-event(event) => {
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                self.pressed-value = root.value;
            }
        }

        moved => {
            if (self.pressed) {
                value = clamp(
                    minimum + (touch.mouse-x / root.width) * (maximum - minimum),
                    minimum,
                    maximum
                );
                root.changed(value);
            }
        }
    }
}

