// tab button for runic menus with active state indicator
import { Theme } from "theme.slint";

export component RunicTabButton inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    in property <length> button-height: 32px;
    in property <length> font-size: 14px;
    callback clicked();

    height: button-height;
    background: transparent;

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        width: parent.width;
        text: label;
        color: active ? Theme.highlight : Theme.stone-edge;
        font-size: root.font-size;
        font-weight: active ? 700 : 400;
        letter-spacing: 2px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    if active: Rectangle {
        property <float> indicator-size-ratio: 0.1875; // 6px for 32px button
        property <length> indicator-size: button-height / 1px * indicator-size-ratio * 1px;
        y: parent.height - indicator-size;
        x: (parent.width - self.width) / 2;
        width: indicator-size;
        height: indicator-size;
        background: Theme.runic-gold;
    }
}

