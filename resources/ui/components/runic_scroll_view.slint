// custom scroll view with runic-themed scrollbar
import { Theme } from "theme.slint";

export component RunicScrollView inherits Rectangle {
    in property <length> viewport-height;
    out property <length> viewport-y: -flickable.viewport-y;

    // public function to scroll by delta (for external scroll wheel handling)
    public function scroll-by(delta-y: length) {
        if flickable.viewport-height > flickable.height {
            flickable.viewport-y = clamp(
                flickable.viewport-y + delta-y,
                -(flickable.viewport-height - flickable.height),
                0px
            );
        }
    }

    background: transparent;

    flickable := Flickable {
        x: 0;
        y: 0;
        width: parent.width - 14px;
        height: parent.height;
        viewport-height: root.viewport-height;
        interactive: true; // allow scrolling and clicks

        @children
    }

    // scrollbar track
    track := Rectangle {
        property <length> track-height: root.height - 8px;
        property <length> max-scroll: flickable.viewport-height - flickable.height;
        property <float> scroll-ratio: max-scroll > 0px ? -flickable.viewport-y / max-scroll : 0;
        property <length> thumb-height: max(30px, track-height * (flickable.height / flickable.viewport-height));
        property <length> available-track: track-height - thumb-height;

        x: parent.width - 10px;
        y: 4px;
        width: 10px;
        height: track-height;
        background: rgba(15, 23, 42, 0.5);
        border-width: 0;
        border-color: transparent;
        visible: flickable.viewport-height > flickable.height;

        // left border line
        Rectangle {
            x: 0;
            y: 0;
            width: 1px;
            height: parent.height;
            background: Theme.stone-dark;
        }

        // scrollbar thumb
        thumb := Rectangle {
            x: 0;
            y: track.scroll-ratio * track.available-track;
            width: parent.width;
            height: track.thumb-height;
            background: touch.pressed ? Theme.runic-gold : touch.has-hover ? Theme.stone-light : Theme.stone-mild;
            border-width: 1px;
            border-color: touch.pressed ? Theme.icon-glow : touch.has-hover ? Theme.stone-edge : Theme.stone-dark;

            // inner highlight
            Rectangle {
                x: 1px;
                y: 1px;
                width: parent.width - 2px;
                height: 1px;
                background: rgba(255, 255, 255, 0.1);
            }

            touch := TouchArea {
                property <length> drag-start-y;
                property <length> drag-start-viewport-y;

                pointer-event(event) => {
                    if event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                        drag-start-y = self.mouse-y;
                        drag-start-viewport-y = flickable.viewport-y;
                    }
                }

                moved => {
                    if self.pressed {
                        // calculate new scroll position based on drag
                        flickable.viewport-y = clamp(
                            drag-start-viewport-y - (self.mouse-y - drag-start-y) * (track.max-scroll / track.available-track),
                            -track.max-scroll,
                            0px
                        );
                    }
                }
            }
        }
    }
}

