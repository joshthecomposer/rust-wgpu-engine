// runic-styled modal window frame with shadow and corner decorations
import { Theme } from "theme.slint";

export component RunicWindow inherits Rectangle {
    in property <length> window-width: 420px;
    in property <length> window-height: 400px;
    in property <bool> show-shadow: true;

    width: window-width;
    height: window-height;
    background: transparent;

    if show-shadow : Rectangle {
        x: 4px;
        y: 4px;
        width: parent.width;
        height: parent.height;
        background: #000000.with-alpha(0.6);
    }

    panel := Rectangle {
        width: parent.width;
        height: parent.height;
        background: Theme.deep-void;
        border-width: 2px;
        border-color: Theme.stone-light;

        // corner decorations (top-left)
        Rectangle {
            x: -4px;
            y: -4px;
            width: 14px;
            height: 2px;
            background: Theme.runic-gold;
        }
        Rectangle {
            x: -4px;
            y: -4px;
            width: 2px;
            height: 14px;
            background: Theme.runic-gold;
        }

        // corner decorations (top-right)
        Rectangle {
            x: parent.width - 10px;
            y: -4px;
            width: 14px;
            height: 2px;
            background: Theme.runic-gold;
        }
        Rectangle {
            x: parent.width + 2px;
            y: -4px;
            width: 2px;
            height: 14px;
            background: Theme.runic-gold;
        }

        // corner decorations (bottom-left)
        Rectangle {
            x: -4px;
            y: parent.height + 2px;
            width: 14px;
            height: 2px;
            background: Theme.runic-gold;
        }
        Rectangle {
            x: -4px;
            y: parent.height - 10px;
            width: 2px;
            height: 14px;
            background: Theme.runic-gold;
        }

        // corner decorations (bottom-right)
        Rectangle {
            x: parent.width - 10px;
            y: parent.height + 2px;
            width: 14px;
            height: 2px;
            background: Theme.runic-gold;
        }
        Rectangle {
            x: parent.width + 2px;
            y: parent.height - 10px;
            width: 2px;
            height: 14px;
            background: Theme.runic-gold;
        }

        @children
    }
}

