// Root Slint file for in-game UI (pause menu, HUD, etc.)
// This single component manages all game UI in one window.

// import custom fonts for game UI - must be at root level for embedding
import "../fonts/weiholmir.ttf";
import "../fonts/JetBrainsMono-Medium.ttf";
import "../fonts/OpenDyslexic-Regular.otf";

import { PlayerContainer } from "components/player_container.slint";
import { PauseMenu } from "pause_menu.slint";
import { FpsCounter } from "components/fps_counter.slint";
import { Toast } from "components/toast.slint";
import { Theme } from "components/theme.slint";
import { AbilityBar, AbilitySlotData } from "components/ability_bar.slint";

export component GameRoot inherits Window {
    background: transparent;
    in-out property <string> font-family: "Weiholmir"; // display name for UI
    in-out property <string> actual-font-family: "Weiholmir"; // actual font family name for rendering
    default-font-family: root.actual-font-family;

    // pause menu properties
    in property <bool> show-pause-menu: false;

    // settings properties
    in-out property <string> resolution: "1920 x 1080";
    in-out property <string> window-mode: "Windowed";
    in-out property <bool> gizmo-enabled: false;
    in-out property <bool> show-fps: false;
    in-out property <float> bgm-volume: 100.0;
    in-out property <float> sfx-volume: 80.0;
    in-out property <bool> vsync: true;
    in-out property <bool> debug-mode: false;
    in-out property <string> msaa: "16x MSAA";

    in property <int> current-fps: 60;

    in property <string> build-version: "v0.0.1a";

    // ==================== TOAST NOTIFICATIONS ====================
    in property <[{id: int, toast-type: int, title: string, message: string, state: int}]> toasts: [];

    callback close_clicked();
    callback reload_world_clicked();
    callback save_player_clicked();
    callback quit_clicked();
    callback apply_settings_clicked();
    callback cancel_settings_clicked();
    callback toast_close_clicked(int);

    // ==================== PLAYER HUD PROPERTIES ====================
    in property <bool> show-player-hud: true;
    in property <string> player-name: "PLAYER";
    in property <int> player-level: 1;
    in property <float> player-health: 100;
    in property <float> player-health-max: 100;
    in property <float> player-mana: 100;
    in property <float> player-mana-max: 100;

    // ==================== ABILITY BAR PROPERTIES ====================
    in property <bool> show-ability-bar: true;
    in property <AbilitySlotData> ability-slot-m1: { visible: true, ability-id: 0, key-label: "M1", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true };
    in property <AbilitySlotData> ability-slot-m2: { visible: true, ability-id: 0, key-label: "M2", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true };
    in property <AbilitySlotData> ability-slot-q: { visible: true, ability-id: 0, key-label: "Q", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true };
    in property <AbilitySlotData> ability-slot-e: { visible: true, ability-id: 0, key-label: "E", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true };
    in property <AbilitySlotData> ability-slot-shift: { visible: true, ability-id: 0, key-label: "Shift", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true };
    in property <AbilitySlotData> ability-slot-r: { visible: true, ability-id: 0, key-label: "R", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true };

    // ==================== PICKUP PROMPT ====================
    in property <bool> show-pickup-prompt: false;

    // expose portrait rect for GL rendering (absolute screen position)
    out property <length> portrait-x: player-hud.x + player-hud.portrait-x;
    out property <length> portrait-y: player-hud.y + player-hud.portrait-y;
    out property <length> portrait-width: player-hud.portrait-width;
    out property <length> portrait-height: player-hud.portrait-height;

    // expose ability bar rect for GL rendering (absolute screen position)
    out property <length> ability_bar_x: ability-bar.x;
    out property <length> ability_bar_y: ability-bar.y;
    out property <length> ability_bar_width: ability-bar.width;
    out property <length> ability_bar_height: ability-bar.height;

    // ==================== PLAYER HUD ====================
    player-hud := PlayerContainer {
        x: 16px;
        y: 16px;

        show-hud: show-player-hud;
        player-name: root.player-name;
        level: root.player-level;
        health-current: root.player-health;
        health-max: root.player-health-max;
        mana-current: root.player-mana;
        mana-max: root.player-mana-max;
    }

    // ==================== ABILITY BAR ====================
    ability-bar := AbilityBar {
        x: 16px;
        y: parent.height - self.height - 24px;
        show: root.show-ability-bar && !root.show-pause-menu;
        slot-m1: root.ability-slot-m1;
        slot-m2: root.ability-slot-m2;
        slot-q: root.ability-slot-q;
        slot-e: root.ability-slot-e;
        slot-shift: root.ability-slot-shift;
        slot-r: root.ability-slot-r;
    }

    // ==================== FPS COUNTER ====================
    FpsCounter {
        x: parent.width - self.width - 16px;
        y: 16px;
        fps: root.current-fps;
        show: root.show-fps;
    }

    // ==================== PICKUP PROMPT ====================
    if root.show-pickup-prompt: Rectangle {
        x: (parent.width - self.width) / 2;
        y: parent.height * 0.6;
        width: prompt-text.preferred-width + 32px;
        height: prompt-text.preferred-height + 16px;
        background: #000000.with-alpha(0.7);
        border-radius: 8px;
        border-width: 2px;
        border-color: Theme.highlight;

        prompt-text := Text {
            x: 16px;
            y: 8px;
            text: "Press G to pick up";
            color: Theme.highlight;
            font-size: 18px;
            font-weight: 600;
        }
    }

    // ==================== PAUSE MENU ====================
    PauseMenu {
        show-pause-menu: root.show-pause-menu;
        build-version: root.build-version;
        resolution <=> root.resolution;
        window-mode <=> root.window-mode;
        gizmo-enabled <=> root.gizmo-enabled;
        show-fps <=> root.show-fps;
        bgm-volume <=> root.bgm-volume;
        sfx-volume <=> root.sfx-volume;
        vsync <=> root.vsync;
        debug-mode <=> root.debug-mode;
        msaa <=> root.msaa;
        font-family <=> root.font-family;
        actual-font-family <=> root.actual-font-family;

        close_clicked => { root.close_clicked(); }
        reload_world_clicked => { root.reload_world_clicked(); }
        save_player_clicked => { root.save_player_clicked(); }
        quit_clicked => { root.quit_clicked(); }
        apply_settings_clicked => { root.apply_settings_clicked(); }
        cancel_settings_clicked => { root.cancel_settings_clicked(); }
    }

    // ==================== TOAST NOTIFICATIONS ====================
    // positioned in bottom-right corner, stacks vertically
    // accounts for 4px shadow offset on right and bottom
    toast-container := Rectangle {
        x: parent.width - self.width - 24px;
        y: parent.height - self.height - 24px;
        width: 400px;
        height: toast-layout.preferred-height;
        background: transparent;
        clip: false;

        toast-layout := VerticalLayout {
            spacing: 12px;
            alignment: end;

            for toast in toasts: Toast {
                toast-type: toast.toast-type;
                title: toast.title;
                message: toast.message;
                toast-id: toast.id;
                state: toast.state;
                close-clicked(id) => { root.toast_close_clicked(id); }
            }
        }
    }
}

// Export AbilityBarStandalone component for FBO rendering
// This is a separate component from the main UI to avoid triggering re-renders
export component AbilityBarStandalone inherits Window {
    background: transparent;
    default-font-family: "Weiholmir";

    in property <bool> show: true;
    in property <AbilitySlotData> slot-m1: { visible: true, ability-id: 0, key-label: "M1", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true, ability-name: "", ability-description: "", ability-effects: "" };
    in property <AbilitySlotData> slot-m2: { visible: true, ability-id: 0, key-label: "M2", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true, ability-name: "", ability-description: "", ability-effects: "" };
    in property <AbilitySlotData> slot-q: { visible: true, ability-id: 0, key-label: "Q", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true, ability-name: "", ability-description: "", ability-effects: "" };
    in property <AbilitySlotData> slot-e: { visible: true, ability-id: 0, key-label: "E", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true, ability-name: "", ability-description: "", ability-effects: "" };
    in property <AbilitySlotData> slot-shift: { visible: true, ability-id: 0, key-label: "Shift", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true, ability-name: "", ability-description: "", ability-effects: "" };
    in property <AbilitySlotData> slot-r: { visible: true, ability-id: 0, key-label: "R", cooldown-progress: 0, cooldown-time-remaining: 0, is-ready: true, ability-name: "", ability-description: "", ability-effects: "" };

    AbilityBar {
        x: 0;
        y: 0;
        show: root.show;
        slot-m1: root.slot-m1;
        slot-m2: root.slot-m2;
        slot-q: root.slot-q;
        slot-e: root.slot-e;
        slot-shift: root.slot-shift;
        slot-r: root.slot-r;
    }
}
