                        id: Some("tex_2"),
                        width: Px(100.0),
                        height: Px(100.0),
                    )
                )
            ]
        ),
        Label(
            content: "Press 'F' to cycle views",
            style: (
                margin: Px(40.0),
                color: Some(Rgba(0.7, 0.7, 0.7, 1.0)),
                font_size: Some(16.0),
            )
        )
    ]
)
