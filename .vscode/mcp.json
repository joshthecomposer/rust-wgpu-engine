{
  "servers": {
    "sequentialThinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "codeIndexer": {
      "command": "uvx",
      "args": [
        "--with",
        "watchdog",
        "code-index-mcp"
      ]
    }
  }
}